# ──────────────────────────────────────────────────────────────────────────────
# Telecom Churn API — Environment Variables Template
# Copy this file to `.env` and fill in your values.
# NEVER commit the real .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false

# ── Model ─────────────────────────────────────────────────────────────────────
# Absolute or relative path to the joblib pipeline
MODEL_PATH=../telecom_churn_pipeline.joblib

# Absolute or relative path to the model metadata JSON
METADATA_PATH=../model_metadata.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
# Set to "true" to emit JSON on the console too (useful for cloud log aggregators)
LOG_JSON_CONSOLE=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100/minute
# Uncomment to use Redis-backed storage for rate limits (recommended in production)
# REDIS_URL=redis://redis:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development only.
CORS_ORIGINS=*

# ── Security (optional) ───────────────────────────────────────────────────────
# API_KEY=change_me_to_a_long_random_string

# ── Environment tag ───────────────────────────────────────────────────────────
ENVIRONMENT=development
