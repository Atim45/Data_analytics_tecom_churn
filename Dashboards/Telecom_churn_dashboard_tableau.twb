      <aliases enabled='yes' />
      <column caption='Churn count' datatype='integer' name='[Calculation_0525588955234308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[churn]' />
      </column>
      <column caption='Churn flag' datatype='boolean' name='[Calculation_0525588955856901]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[churn]=1' />
      </column>
      <column caption='Total customers' datatype='integer' name='[Calculation_0525588956008454]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id])' />
      </column>
      <column caption='Retained Customers' datatype='integer' name='[Calculation_0525588960722951]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id]) - SUM([churn])' />
      </column>
      <column caption='Churn Rate ' datatype='real' datatype-customized='true' name='[Calculation_0525588961701896]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0525588955234308])' />
      </column>
      <column caption='Retention Rate %' datatype='real' name='[Calculation_0525588961800201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - SUM([churn]) / COUNT([customer_id])' />
      </column>
      <column caption='Average Estimated Salary' datatype='real' name='[Calculation_0525588961931274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([estimated_salary])' />
      </column>
      <column caption='MRR At Risk' datatype='real' name='[Calculation_0525588962209803]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [churn]=1&#13;&#10;&#13;&#10;THEN [estimated_salary]*0.05&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='Campaign Recovery Revenue' datatype='real' name='[Calculation_0525588962312204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0525588962209803] * 0.15' />
      </column>
      <column caption='Revenue Saved Potential' datatype='real' name='[Calculation_0525588962418701]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0525588962209803] * 0.25' />
      </column>
      <column caption='Average Calls' datatype='real' name='[Calculation_0525588962496526]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([calls_made])' />
      </column>
      <column caption='Average Data Usage' datatype='real' name='[Calculation_0525588962619407]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([data_used])' />
      </column>
      <column caption='Average SMS' datatype='real' name='[Calculation_0525588962693136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([sms_sent])' />
      </column>
      <column caption='Average Usage Score' datatype='real' name='[Calculation_0525588962795537]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([usage_score])' />
      </column>
      <column caption='Low Engagement Count' datatype='integer' name='[Calculation_0525588962877458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [is_low_engagement]=1&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='Age Band' datatype='string' name='[Calculation_0525588962983955]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt;=30 THEN &quot;18-30&quot;&#13;&#10;&#13;&#10;ELSEIF [age]&lt;=45 THEN &quot;31-45&quot;&#13;&#10;&#13;&#10;ELSEIF [age]&lt;=60 THEN &quot;46-60&quot;&#13;&#10;&#13;&#10;ELSE &quot;61+&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Salary Band' datatype='string' name='[Calculation_0525588963106836]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [estimated_salary] &lt;50000 THEN &quot;Low&quot;&#13;&#10;&#13;&#10;ELSEIF [estimated_salary] &lt;100000 THEN &quot;Medium&quot;&#13;&#10;&#13;&#10;ELSEIF [estimated_salary] &lt;150000 THEN &quot;High&quot;&#13;&#10;&#13;&#10;ELSE &quot;Premium&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Tenure Cohort' datatype='string' name='[Calculation_0525588963192853]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure_months] &lt;=6 THEN &quot;0-6 Months&quot;&#13;&#10;&#13;&#10;ELSEIF [tenure_months]&lt;=12 THEN &quot;7-12 Months&quot;&#13;&#10;&#13;&#10;ELSEIF [tenure_months]&lt;=24 THEN &quot;13-24 Months&quot;&#13;&#10;&#13;&#10;ELSE &quot;24+ Months&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Usage Segment' datatype='string' name='[Calculation_0525588963274774]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [usage_score] &lt;0.5 THEN &quot;Dormant&quot;&#13;&#10;&#13;&#10;ELSEIF [usage_score]&lt;1 THEN &quot;Light&quot;&#13;&#10;&#13;&#10;ELSEIF [usage_score]&lt;1.5 THEN &quot;Moderate&quot;&#13;&#10;&#13;&#10;ELSEIF [usage_score]&lt;2 THEN &quot;Heavy&quot;&#13;&#10;&#13;&#10;ELSE &quot;Power User&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Prediction Accuracy' datatype='string' name='[Calculation_0525588963356695]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [churn]=[predicted_churn]&#13;&#10;&#13;&#10;THEN &quot;Correct&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Wrong&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Prediction Accuracy %' datatype='real' name='[Calculation_0525588963442712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;&#13;&#10;IF [churn]=[predicted_churn]&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='High Risk Customers' datatype='string' name='[Calculation_0525588963528729]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [predicted_prob] &gt;=0.70&#13;&#10;&#13;&#10;THEN &quot;High Risk&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Normal&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Risk Score %' datatype='real' name='[Calculation_0525588963610650]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([predicted_prob])' />
      </column>
      <column caption='High Risk Count' datatype='integer' name='[Calculation_0525588963680283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [predicted_prob]&gt;=0.70&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='False Positives' datatype='integer' name='[Calculation_0525588963770396]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [predicted_churn]=1&#13;&#10;&#13;&#10;AND [churn]=0&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='False Negatives' datatype='integer' name='[Calculation_0525588963844125]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [predicted_churn]=0&#13;&#10;&#13;&#10;AND [churn]=1&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='True Positives' datatype='integer' name='[Calculation_0525588963942430]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [predicted_churn]=1&#13;&#10;&#13;&#10;AND [churn]=1&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='True Negatives' datatype='integer' name='[Calculation_0525588964020255]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;&#13;&#10;IF [predicted_churn]=0&#13;&#10;&#13;&#10;AND [churn]=0&#13;&#10;&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;&#13;&#10;END&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='Partner Churn Rate' datatype='real' name='[Calculation_0525588964110368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [telecom_partner]:&#13;&#10;&#13;&#10;AVG([churn])&#13;&#10;&#13;&#10;}' />
