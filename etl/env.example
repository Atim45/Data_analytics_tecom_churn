# =============================================================================
# Telecom Churn ETL — Environment Configuration Template
#
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# =============================================================================

# --- PostgreSQL connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=telecom_churn_db
DB_SCHEMA=churn
DB_USER=churn_etl
DB_PASSWORD=changeme

# --- SQLAlchemy engine tuning ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_CONNECT_TIMEOUT_SECONDS=10

# --- Source data ---
CSV_PATH=data/telecom_churn.csv

# --- Pipeline behavior ---
# Snapshot date represents the "as of" date for this fact_usage load
# (i.e. the reporting date used to compute tenure_months and to resolve
# fact_usage.snapshot_date_id). Format: YYYY-MM-DD.
# If left blank, the pipeline uses the current system date.
SNAPSHOT_DATE=

# Row batch size used for bulk INSERT operations.
BULK_INSERT_BATCH_SIZE=5000

# If TRUE, rows that fail validation are dropped (with a warning logged)
# instead of aborting the whole pipeline.
DROP_INVALID_ROWS=TRUE

# Directory where JSON/text validation reports are written.
REPORTS_DIR=reports

# Directory where log files are written.
LOGS_DIR=logs

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
